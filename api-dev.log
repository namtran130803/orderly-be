    SELECT COALESCE(SUM(oi.price_snapshot * oi.qty), 0) AS total
    FROM order_items oi
    JOIN orders o ON o.id = oi.order_id
    WHERE o.store_id = $1
      AND o.created_at >= $2
      AND o.created_at < $3
      AND o.status_id = $4
  
