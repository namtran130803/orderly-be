# Database
POSTGRES_USER=orderly_user
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=orderly_db
DATABASE_URL=postgresql://orderly_user:supersecret@localhost:5432/orderly_db

# JWT
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=3000

# Soketi (Pusher-compatible WebSocket) — docker compose service `soketi`
PUSHER_APP_ID=orderly-app
PUSHER_APP_KEY=orderly-key
PUSHER_APP_SECRET=orderly-secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_USE_TLS=false
SOKETI_DEBUG=1
SOKETI_METRICS_PORT=9601

