generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusType {
  start
  mid
  end
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  stores       Store[]

  @@map("users")
}

model Store {
  id         Int        @id @default(autoincrement())
  userId     Int        @map("user_id")
  name       String
  address    String?
  createdAt  DateTime   @default(now()) @map("created_at")
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories Category[]
  areas      Area[]
  statuses   Status[]
  orders     Order[]
  expenses   Expense[]

  @@map("stores")
}

model Category {
  id        Int        @id @default(autoincrement())
  storeId   Int        @map("store_id")
  name      String
  sortOrder Int        @default(0) @map("sort_order")
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          Int         @id @default(autoincrement())
  categoryId  Int         @map("category_id")
  name        String
  price       Decimal     @db.Decimal(12, 0)
  isAvailable Boolean     @default(true) @map("is_available")
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@map("menu_items")
}

model Area {
  id        Int     @id @default(autoincrement())
  storeId   Int     @map("store_id")
  name      String
  sortOrder Int     @default(0) @map("sort_order")
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tables    Table[]

  @@map("areas")
}

model Table {
  id        Int    @id @default(autoincrement())
  areaId    Int    @map("area_id")
  name      String
  orderId   Int?   @map("order_id")
  sortOrder Int    @default(0) @map("sort_order")
  area      Area   @relation(fields: [areaId], references: [id], onDelete: Cascade)
  order     Order?

  @@map("tables")
}

model Status {
  id         Int         @id @default(autoincrement())
  storeId    Int         @map("store_id")
  name       String
  type       StatusType
  sortOrder  Int         @map("sort_order")
  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([storeId, sortOrder])
  @@map("statuses")
}

model Order {
  id             Int         @id @default(autoincrement())
  storeId        Int         @map("store_id")
  tableId        Int?        @unique @map("table_id")
  tableSnapshot  String?     @map("table_snapshot")
  statusSnapshot String?     @map("status_snapshot")
  orderNumber    Int         @map("order_number")
  createdAt      DateTime    @default(now()) @map("created_at")
  store          Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table          Table?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  items          OrderItem[]

  @@unique([storeId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id            Int       @id @default(autoincrement())
  orderId       Int       @map("order_id")
  menuItemId    Int?      @map("menu_item_id")
  statusId      Int       @map("status_id")
  nameSnapshot  String    @map("name_snapshot")
  priceSnapshot Decimal   @map("price_snapshot") @db.Decimal(12, 0)
  qty           Int
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem      MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  status        Status    @relation(fields: [statusId], references: [id])

  @@map("order_items")
}

model Expense {
  id          Int      @id @default(autoincrement())
  storeId     Int      @map("store_id")
  title       String
  description String?
  amount      Decimal  @db.Decimal(15, 0)
  rawDate     DateTime @default(now()) @map("raw_date")
  createdAt   DateTime @default(now()) @map("created_at")
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("expenses")
}
