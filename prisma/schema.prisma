generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusType {
  start
  mid
  end
}

enum SalaryType {
  MONTHLY
  HOURLY
}

enum AttendanceStatus {
  WORK
  PAID_LEAVE
  UNPAID_LEAVE
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OverrideType {
  OFF
  WORKING_DAY
}

model User {
  id           Int         @id @default(autoincrement())
  name         String
  phone        String      @unique
  passwordHash String      @map("password_hash")
  createdAt    DateTime    @default(now()) @map("created_at")
  stores       Store[]
  userRoles           UserRole[]
  storeUsers          StoreUser[]
  attendanceEditLogs  AttendanceEditLog[] @relation("AttendanceEditLogEditor")
  reviewedLeaveReqs   LeaveRequest[]      @relation("LeaveReviewer")

  @@map("users")
}

model Store {
  id               Int                @id @default(autoincrement())
  userId           Int                @map("user_id")
  name             String
  address          String?
  createdAt        DateTime           @default(now()) @map("created_at")
  defaultWorkDays  Int[]              @default([1, 2, 3, 4, 5]) @map("default_work_days")
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories       Category[]
  areas            Area[]
  statuses         Status[]
  orders           Order[]
  expenses         Expense[]
  storeUsers       StoreUser[]
  storeRoles       StoreRole[]
  scheduleOverrides ScheduleOverride[]
  leaveRequests    LeaveRequest[]
  payrollSnapshots PayrollSnapshot[]

  @@map("stores")
}

model Category {
  id        Int        @id @default(autoincrement())
  storeId   Int        @map("store_id")
  name      String
  sortOrder Int        @default(0) @map("sort_order")
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  name        String
  price       Int
  isAvailable Boolean  @default(true) @map("is_available")
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}

model Area {
  id        Int     @id @default(autoincrement())
  storeId   Int     @map("store_id")
  name      String
  sortOrder Int     @default(0) @map("sort_order")
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tables    Table[]

  @@map("areas")
}

model Table {
  id        Int     @id @default(autoincrement())
  areaId    Int     @map("area_id")
  name      String
  orderId   Int?    @map("order_id")
  sortOrder Int     @default(0) @map("sort_order")
  area      Area    @relation(fields: [areaId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@map("tables")
}

model Status {
  id         Int         @id @default(autoincrement())
  storeId    Int         @map("store_id")
  name       String
  type       StatusType
  sortOrder  Int         @map("sort_order")
  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders     Order[]
  orderItems OrderItem[]

  @@unique([storeId, sortOrder])
  @@map("statuses")
}

model Order {
  id             Int         @id @default(autoincrement())
  storeId        Int         @map("store_id")
  tableId        Int?        @map("table_id")
  tableSnapshot  String?     @map("table_snapshot")
  statusId       Int?        @map("status_id")
  statusSnapshot String?     @map("status_snapshot")
  createdAt      DateTime    @default(now()) @map("created_at")
  store          Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  status         Status?     @relation(fields: [statusId], references: [id])
  table          Table?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  items          OrderItem[]

  @@map("orders")
}

model OrderItem {
  id             Int     @id @default(autoincrement())
  orderId        Int     @map("order_id")
  statusId       Int?    @map("status_id")
  statusSnapshot String? @map("status_snapshot")
  nameSnapshot   String  @map("name_snapshot")
  priceSnapshot  Int     @map("price_snapshot")
  qty            Int
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status         Status? @relation(fields: [statusId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model Expense {
  id          Int      @id @default(autoincrement())
  storeId     Int      @map("store_id")
  title       String
  description String?
  amount      Int
  rawDate     DateTime @default(now()) @map("raw_date")
  createdAt   DateTime @default(now()) @map("created_at")
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ── RBAC: Phân quyền động ─────────────────────────────────────

model Permission {
  id             Int                   @id @default(autoincrement())
  code           String                @unique
  name           String
  rolePerms      RolePermission[]
  storeRolePerms StoreRolePermission[]

  @@map("permissions")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  code        String           @unique
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId Int  @map("user_id")
  roleId Int  @map("role_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ── Store-level RBAC ─────────────────────────────────────────────

enum StoreUserRoleType {
  owner
  employee
}

model StoreUser {
  id           Int               @id @default(autoincrement())
  userId       Int               @map("user_id")
  storeId      Int               @map("store_id")
  role         StoreUserRoleType @default(employee)
  salaryType   SalaryType        @default(MONTHLY) @map("salary_type")
  baseSalary   Int               @default(0) @map("base_salary")
  workDays     Int[]             @default([]) @map("work_days")
  hourlyRate   Int?              @map("hourly_rate")
  createdAt    DateTime          @default(now()) @map("created_at")
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  store        Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  roles        StoreUserRole[]
  attendances  Attendance[]
  leaveRequests LeaveRequest[]
  payrollSnapshots PayrollSnapshot[]

  @@unique([userId, storeId])
  @@map("store_users")
}

model ScheduleOverride {
  id      Int          @id @default(autoincrement())
  storeId Int          @map("store_id")
  date    DateTime     @db.Date
  type    OverrideType
  store   Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@map("schedule_overrides")
}

model Attendance {
  id          Int              @id @default(autoincrement())
  employeeId  Int              @map("employee_id")
  date        DateTime         @db.Date
  checkIn     DateTime?        @map("check_in")
  checkOut    DateTime?        @map("check_out")
  workMinutes Int?             @map("work_minutes")
  status      AttendanceStatus
  note        String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  employee    StoreUser        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  editLogs    AttendanceEditLog[]

  @@unique([employeeId, date])
  @@map("attendances")
}

model AttendanceEditLog {
  id           Int        @id @default(autoincrement())
  attendanceId Int        @map("attendance_id")
  before       Json
  after        Json
  editedBy     Int        @map("edited_by")
  createdAt    DateTime   @default(now()) @map("created_at")
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  editor       User       @relation("AttendanceEditLogEditor", fields: [editedBy], references: [id], onDelete: Cascade)

  @@map("attendance_edit_logs")
}

model LeaveRequest {
  id         Int                @id @default(autoincrement())
  storeId    Int                @map("store_id")
  employeeId Int                @map("employee_id")
  fromDate   DateTime           @map("from_date") @db.Date
  toDate     DateTime           @map("to_date") @db.Date
  isPaid     Boolean            @map("is_paid")
  reason     String?
  status     LeaveRequestStatus @default(PENDING)
  reviewedBy Int?               @map("reviewed_by")
  createdAt  DateTime           @default(now()) @map("created_at")
  store      Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  employee   StoreUser          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer   User?              @relation("LeaveReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@map("leave_requests")
}

model PayrollSnapshot {
  id           Int       @id @default(autoincrement())
  storeId      Int       @map("store_id")
  employeeId   Int       @map("employee_id")
  month        Int
  year         Int
  standardDays Int       @map("standard_days")
  paidDays     Int       @map("paid_days")
  salary       Int
  lockedAt     DateTime  @default(now()) @map("locked_at")
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  employee     StoreUser @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([storeId, employeeId, month, year])
  @@map("payroll_snapshots")
}

model StoreRole {
  id          Int                   @id @default(autoincrement())
  storeId     Int                   @map("store_id")
  name        String
  store       Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  permissions StoreRolePermission[]
  roles       StoreUserRole[]

  @@unique([storeId, name])
  @@map("store_roles")
}

model StoreRolePermission {
  storeRoleId  Int        @map("store_role_id")
  permissionId Int        @map("permission_id")
  storeRole    StoreRole  @relation(fields: [storeRoleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([storeRoleId, permissionId])
  @@map("store_role_permissions")
}

model StoreUserRole {
  storeUserId Int       @map("store_user_id")
  storeRoleId Int       @map("store_role_id")
  storeUser   StoreUser @relation(fields: [storeUserId], references: [id], onDelete: Cascade)
  storeRole   StoreRole @relation(fields: [storeRoleId], references: [id], onDelete: Cascade)

  @@id([storeUserId, storeRoleId])
  @@map("store_user_roles")
}
